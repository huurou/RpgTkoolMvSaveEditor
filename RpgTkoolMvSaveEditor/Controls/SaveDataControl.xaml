<UserControl x:Class="RpgTkoolMvSaveEditor.Controls.SaveDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:RpgTkoolMvSaveEditor.Controls" d:DataContext="{d:DesignInstance Type=controls:SaveDataControlVM}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <GroupBox Header="SaveData">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <controls:SwitchesControl Grid.Column="0" Source="{Binding Switches}" />
            <controls:VariablesControl Grid.Column="1" Source="{Binding Variables}" />
        </Grid>
    </GroupBox>
</UserControl>
